<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eba.propertyconnect.propertymanagement.leasing.mapper.LeadMapper">
	<resultMap id="resultMapLead" type="com.eba.propertyconnect.propertymanagement.leasing.domain.Lead">
		<id column="id" property="id" jdbcType="BIGINT" />
		<result column="lead_no" property="leadNo" jdbcType="VARCHAR" />
		<result column="customer_name" property="customerName" jdbcType="VARCHAR" />
		<result column="mobile_no" property="mobileNo" jdbcType="VARCHAR" />
		<result column="email" property="email" jdbcType="VARCHAR" />
		<result column="source" property="source" jdbcType="VARCHAR" />
		<result column="purpose" property="purpose" jdbcType="VARCHAR" />
		<result column="status" property="status" jdbcType="VARCHAR" />
		<result column="qualification_score" property="qualificationScore" jdbcType="INTEGER" />
		<result column="qualification_notes" property="qualificationNotes" jdbcType="VARCHAR" />
		<result column="created_by" property="createdBy" jdbcType="BIGINT" />
		<result column="created_at" property="createdAt" jdbcType="TIMESTAMP" />
		<result column="updated_by" property="updatedBy" jdbcType="BIGINT" />
		<result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP" />
	</resultMap>
	<select id="listLeads" resultMap="resultMapLead">SELECT * FROM pa_txn_leasing_lead ORDER BY created_at DESC</select>
	<select id="getLead" parameterType="long" resultMap="resultMapLead">SELECT * FROM pa_txn_leasing_lead WHERE id = #{id, jdbcType=BIGINT}</select>
	<insert id="createLead" parameterType="com.eba.propertyconnect.propertymanagement.leasing.domain.Lead">
		INSERT INTO pa_txn_leasing_lead (lead_no, customer_name, mobile_no, email, source, purpose, status, created_by)
		VALUES (#{leadNo}, #{customerName}, #{mobileNo}, #{email}, #{source}, #{purpose}, #{status}, #{createdBy})
		<selectKey keyProperty="id" resultType="long" order="AFTER">SELECT LAST_INSERT_ID()</selectKey>
	</insert>
	<update id="qualifyLead">UPDATE pa_txn_leasing_lead SET status = 'QUALIFIED', qualification_score = #{score}, qualification_notes = #{notes}, updated_by = #{updatedBy} WHERE id = #{id}</update>
	<update id="updateLeadStatus">UPDATE pa_txn_leasing_lead SET status = #{status}, updated_by = #{updatedBy} WHERE id = #{id}</update>
</mapper>
