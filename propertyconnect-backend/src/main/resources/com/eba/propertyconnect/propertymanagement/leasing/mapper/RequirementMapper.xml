<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eba.propertyconnect.propertymanagement.leasing.mapper.RequirementMapper">
	<resultMap id="resultMapRequirement" type="com.eba.propertyconnect.propertymanagement.leasing.domain.Requirement">
		<id column="id" property="id" jdbcType="BIGINT" />
		<result column="prospect_id" property="prospectId" jdbcType="BIGINT" />
		<result column="property_id" property="propertyId" jdbcType="BIGINT" />
		<result column="property_name" property="propertyName" jdbcType="VARCHAR" />
		<result column="unit_type" property="unitType" jdbcType="VARCHAR" />
		<result column="bedrooms" property="bedrooms" jdbcType="INTEGER" />
		<result column="budget_from" property="budgetFrom" jdbcType="DECIMAL" />
		<result column="budget_to" property="budgetTo" jdbcType="DECIMAL" />
		<result column="move_in_date" property="moveInDate" jdbcType="DATE" />
		<result column="notes" property="notes" jdbcType="VARCHAR" />
	</resultMap>
	<insert id="saveRequirement" parameterType="com.eba.propertyconnect.propertymanagement.leasing.domain.Requirement">
		INSERT INTO pa_txn_leasing_requirement (prospect_id, property_id, property_name, unit_type, bedrooms, budget_from, budget_to, move_in_date, notes, created_by)
		VALUES (#{prospectId}, #{propertyId}, #{propertyName}, #{unitType}, #{bedrooms}, #{budgetFrom}, #{budgetTo}, #{moveInDate}, #{notes}, #{createdBy})
		<selectKey keyProperty="id" resultType="long" order="AFTER">SELECT LAST_INSERT_ID()</selectKey>
	</insert>
	<select id="getRequirement" parameterType="long" resultMap="resultMapRequirement">SELECT * FROM pa_txn_leasing_requirement WHERE id = #{id}</select>
</mapper>
